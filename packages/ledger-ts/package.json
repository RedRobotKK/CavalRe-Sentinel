{
  "name": "@cavalre/ledger-ts",
  "version": "0.1.0",
  "description": "Event-driven state replica for Ledger.sol with divergence detection",
  "type": "module",
  "main": "dist/ledger.js",
  "types": "dist/ledger.d.ts",
  "exports": {
    ".": {
      "types": "./dist/ledger.d.ts",
      "import": "./dist/ledger.js"
    },
    "./swapFill": {
      "types": "./dist/swapFill.d.ts",
      "import": "./dist/swapFill.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:verify-rpc": "VERIFY_RPC=true vitest run test/ledger-rpc-verify.test.ts",
    "verify:basics": "tsx test/verify-basics.ts",
    "lint": "eslint src test",
    "format": "prettier --write src test"
  },
  "keywords": ["ledger", "state-replica", "event-driven", "ethereum", "divergence-detection"],
  "author": "CavalRe",
  "license": "MIT",
  "dependencies": {
    "@cavalre/floatlib-ts": "file:../floatlib-ts"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vitest": "^1.1.0",
    "@types/node": "^20.10.0",
    "eslint": "^8.55.0",
    "@typescript-eslint/parser": "^6.16.0",
    "@typescript-eslint/eslint-plugin": "^6.16.0",
    "prettier": "^3.1.0",
    "viem": "^2.0.0",
    "tsx": "^4.7.0"
  }
}
