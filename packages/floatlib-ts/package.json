{
  "name": "@cavalre/floatlib-ts",
  "version": "0.1.0",
  "description": "Canonical fixed-point math library - TypeScript port of FloatLib.sol",
  "type": "module",
  "main": "dist/floatlib.js",
  "types": "dist/floatlib.d.ts",
  "exports": {
    ".": {
      "types": "./dist/floatlib.d.ts",
      "import": "./dist/floatlib.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:solidity-verify": "SOLIDITY_VERIFY=true vitest run test/solidity-verify.test.ts",
    "verify:basics": "tsx test/verify-basics.ts",
    "lint": "eslint src test",
    "format": "prettier --write src test"
  },
  "keywords": [
    "floatlib",
    "fixed-point",
    "arbitrary-precision",
    "ethereum",
    "solidity"
  ],
  "author": "CavalRe",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.3.0",
    "vitest": "^1.1.0",
    "@types/node": "^20.10.0",
    "eslint": "^8.55.0",
    "@typescript-eslint/parser": "^6.16.0",
    "@typescript-eslint/eslint-plugin": "^6.16.0",
    "prettier": "^3.1.0",
    "viem": "^2.0.0",
    "tsx": "^4.7.0"
  }
}
